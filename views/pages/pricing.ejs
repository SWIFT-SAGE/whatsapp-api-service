                                    </tr>
                                    <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                        <td class="py-3 px-4" style="font-weight: 600; color: var(--color-slate-900);"><i class="fas fa-chart-line me-2" style="color: var(--color-teal-500); width: 20px;"></i>Analytics</td>
