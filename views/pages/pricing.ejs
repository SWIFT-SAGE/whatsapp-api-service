                                        <td class="py-3 px-4 text-center" style="background: rgba(33, 128, 141, 0.03); font-weight: 500;">Analytics</td>
                                        <td class="py-3 px-4 text-center" style="color: var(--color-teal-600); font-weight: 600;">Advanced Analytics</td>
