<!-- Overview Section -->
<div id="dashboard-overview" class="dashboard-section">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1" style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;">Dashboard Overview</h2>
            <p class="mb-0 text-muted" style="font-size:13px;">Welcome back! Here's what's happening with your API.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge fs-6" id="plan-badge" style="background:var(--gradient-primary);color:#fff;border-radius:9999px;padding:6px 14px;font-size:13px !important;">Loading...</span>
        </div>
    </div>

    <!-- Stats Cards — Glassmorphism -->
    <div class="row g-4 mb-5">
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-card-glass">
                <div class="stat-icon" style="background:rgba(37,211,102,0.12);color:var(--wa-green-dark);">
                    <i class="fas fa-paper-plane"></i>
                </div>
                <div class="stat-value" id="messages-sent" data-stat="totalMessages">—</div>
                <div class="stat-label">Messages Sent</div>
                <div class="stat-trend up" id="message-limit-text">
                    <i class="fas fa-arrow-up"></i><span>Loading...</span>
                </div>
                <!-- Sparkline SVG -->
                <svg class="sparkline-wrap" width="80" height="36" viewBox="0 0 80 36" fill="none">
                    <polyline points="0,28 15,22 30,18 45,10 60,14 75,4" stroke="var(--wa-green)" stroke-width="2" fill="none" opacity="0.7"/>
                    <polyline points="0,28 15,22 30,18 45,10 60,14 75,4 75,36 0,36" fill="var(--wa-green)" opacity="0.08"/>
                </svg>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-card-glass">
                <div class="stat-icon" style="background:rgba(33,128,141,0.12);color:var(--brand-teal);">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <div class="stat-value" id="active-sessions" data-stat="activeSessions">—</div>
                <div class="stat-label">Active Sessions</div>
                <div class="stat-trend up">
                    <i class="fas fa-circle" style="font-size:8px;"></i><span>WhatsApp connected</span>
                </div>
                <svg class="sparkline-wrap" width="80" height="36" viewBox="0 0 80 36" fill="none">
                    <polyline points="0,30 15,26 30,20 45,24 60,12 75,8" stroke="var(--brand-teal)" stroke-width="2" fill="none" opacity="0.7"/>
                    <polyline points="0,30 15,26 30,20 45,24 60,12 75,8 75,36 0,36" fill="var(--brand-teal)" opacity="0.08"/>
                </svg>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-card-glass">
                <div class="stat-icon" style="background:rgba(245,166,35,0.12);color:#d97706;">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div class="stat-value" id="delivery-rate" data-stat="deliveryRate">—</div>
                <div class="stat-label">Delivery Rate</div>
                <div class="stat-trend up">
                    <i class="fas fa-arrow-up"></i><span>Last 30 days</span>
                </div>
                <svg class="sparkline-wrap" width="80" height="36" viewBox="0 0 80 36" fill="none">
                    <polyline points="0,24 15,20 30,16 45,18 60,8 75,6" stroke="#f59e0b" stroke-width="2" fill="none" opacity="0.7"/>
                    <polyline points="0,24 15,20 30,16 45,18 60,8 75,6 75,36 0,36" fill="#f59e0b" opacity="0.08"/>
                </svg>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-card-glass">
                <div class="stat-icon" style="background:rgba(139,92,246,0.12);color:#7c3aed;">
                    <i class="fas fa-key"></i>
                </div>
                <div class="stat-value" id="total-sessions">—</div>
                <div class="stat-label">Total Sessions</div>
                <div class="stat-trend up">
                    <i class="fas fa-shield-alt" style="font-size:10px;"></i><span>All systems operational</span>
                </div>
                <svg class="sparkline-wrap" width="80" height="36" viewBox="0 0 80 36" fill="none">
                    <polyline points="0,28 15,24 30,28 45,16 60,18 75,10" stroke="#8b5cf6" stroke-width="2" fill="none" opacity="0.7"/>
                    <polyline points="0,28 15,24 30,28 45,16 60,18 75,10 75,36 0,36" fill="#8b5cf6" opacity="0.08"/>
                </svg>
            </div>
        </div>
    </div>


    <!-- Quick Actions -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-paper-plane me-2"></i>Quick Send Message
                    </h5>
                    <form id="quick-message-form">
                        <div class="mb-3">
                            <label class="form-label">Session</label>
                            <div class="d-flex">
                                <select class="form-select" id="quick-session-select" required>
                                    <option value="">Loading sessions...</option>
                                </select>
                                <button type="button" class="btn btn-outline-secondary ms-2" id="refresh-sessions-btn" title="Refresh connected sessions">
                                    <i class="fas fa-sync-alt"></i>
                                </button>
                            </div>
                            <small class="text-muted">Connect a WhatsApp session first if no sessions are available.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="quick-phone" placeholder="+1234567890" required>
                            <small class="text-muted">Include country code (e.g., +91 for India, +1 for US)</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" id="quick-message" rows="3" placeholder="Enter your message here..." required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Media (Optional)</label>
                            <input type="file" class="form-control" id="quick-media" accept="image/*,video/*,audio/*,.pdf,.doc,.docx">
                            <small class="text-muted">Supported: Images, Videos, Audio, PDF, Documents</small>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-send me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-key me-2"></i>API Key
                    </h5>
                    <p class="text-muted">Use this key to authenticate your API requests</p>
                    <div class="input-group">
                        <input type="password" class="form-control" id="api-key"
                            value="Loading..."
                            readonly>
                        <div id="api-key-buttons">
                            <!-- Buttons will be dynamically populated based on API key status -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bot Configuration Section -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title m-0">
                            <i class="fas fa-robot me-2"></i>Chatbot Configuration
                        </h5>
                        <button class="btn btn-outline-primary btn-sm" id="save-bot-config">
                            <i class="fas fa-save me-2"></i>Save Configuration
                        </button>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Bot Name</label>
                            <input type="text" class="form-control" id="bot-name" placeholder="My WhatsApp Bot">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Default Session</label>
                            <select class="form-select" id="bot-default-session">
                                <option value="">Select default session for bot</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Welcome Message</label>
                            <textarea class="form-control" id="bot-welcome" rows="2" placeholder="Hello! How can I help you today?"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fallback Message</label>
                            <textarea class="form-control" id="bot-fallback" rows="2" placeholder="I didn't understand that. Please try again."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Website URL (Optional)</label>
                            <input type="url" class="form-control" id="bot-website" placeholder="https://yourwebsite.com">
                            <small class="text-muted">Link to your custom website or landing page</small>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" id="bot-enabled">
                                <label class="form-check-label" for="bot-enabled">
                                    Enable Auto-Reply Bot
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- File Upload & Bulk Operations -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-upload me-2"></i>Bulk Message Upload
                    </h5>
                    <p class="text-muted">Upload a CSV file to send messages to multiple contacts</p>
                    <form id="bulk-upload-form" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Session</label>
                            <select class="form-select" id="bulk-session-select" required>
                                <option value="">Select a connected session</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <input type="file" class="form-control" id="bulk-csv" accept=".csv" required>
                            <small class="text-muted">Format: phone,message (one per line)</small>
                        </div>
                        <div class="mb-3">
                            <a href="#" class="text-primary" id="download-template">
                                <i class="fas fa-download me-1"></i>Download CSV Template
                            </a>
                        </div>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-upload me-2"></i>Upload & Send
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fas fa-cogs me-2"></i>Quick Actions
                    </h5>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" id="connect-new-session">
                            <i class="fas fa-plus me-2"></i>Connect New WhatsApp Session
                        </button>
                        <button class="btn btn-outline-success" id="test-webhook">
                            <i class="fas fa-webhook me-2"></i>Test Webhook Connection
                        </button>
                        <button class="btn btn-outline-info" id="export-contacts">
                            <i class="fas fa-address-book me-2"></i>Export Contact List
                        </button>
                        <button class="btn btn-outline-warning" id="backup-data">
                            <i class="fas fa-database me-2"></i>Backup Messages Data
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
