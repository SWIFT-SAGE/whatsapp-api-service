        }
        .bmd-metric-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.09); }
        [data-color-scheme="dark"] .bmd-metric-card { background: #1a2a1f; border-color: rgba(255,255,255,0.07); }
        .bmd-metric-inner { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .bmd-metric-label { font-size: 12px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
        [data-color-scheme="dark"] .bmd-metric-label { color: rgba(255,255,255,0.45); }
        .bmd-metric-value { font-size: 30px; font-weight: 900; letter-spacing: -0.03em; color: #111; line-height: 1; }
        [data-color-scheme="dark"] .bmd-metric-value { color: #f0f0f0; }
        .bmd-metric-sub { font-size: 12px; color: #888; margin-top: 4px; }
        [data-color-scheme="dark"] .bmd-metric-sub { color: rgba(255,255,255,0.4); }
        .bmd-metric-icon {
            width: 48px; height: 48px; min-width: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
        }
        .bmd-icon-campaigns { background: rgba(37,211,102,0.12); color: #25D366; }
        .bmd-icon-messages { background: rgba(33,128,141,0.12); color: #21808D; }
        .bmd-icon-contacts { background: rgba(245,166,35,0.12); color: #d97706; }
        .bmd-icon-response { background: rgba(139,92,246,0.12); color: #7c3aed; }

        /* ── Charts ── */
        .bmd-charts-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 18px;
            margin-bottom: 22px;
        }
        @media (max-width: 900px) { .bmd-charts-row { grid-template-columns: 1fr; } }
        .bmd-chart-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            border: 1px solid #f0f2f5;
        }
        [data-color-scheme="dark"] .bmd-chart-card { background: #1a2a1f; border-color: rgba(255,255,255,0.07); }
        .bmd-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }
        .bmd-card-title {
            font-size: 14px;
            font-weight: 700;
            color: #222;
        }
        [data-color-scheme="dark"] .bmd-card-title { color: #f0f0f0; }
        .bmd-chart-legend { display: flex; align-items: center; gap: 4px; font-size: 12px; color: #888; }
        .bmd-legend-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }

        /* ── Bottom Row ── */
        .bmd-bottom-row {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 18px;
        }
        @media (max-width: 1100px) { .bmd-bottom-row { grid-template-columns: 1fr; } }
        .bmd-right-col { display: flex; flex-direction: column; gap: 18px; }

        /* ── Campaign Table ── */
        .bmd-table-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            border: 1px solid #f0f2f5;
        }
        [data-color-scheme="dark"] .bmd-table-card { background: #1a2a1f; border-color: rgba(255,255,255,0.07); }
        .bmd-view-all { font-size: 12px; color: #25D366; font-weight: 600; text-decoration: none; }
        .bmd-table-wrap { overflow-x: auto; }
        .bmd-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .bmd-table th {
            text-align: left; padding: 8px 12px;
            font-size: 11px; font-weight: 700; color: #aaa;
            text-transform: uppercase; letter-spacing: 0.05em;
            border-bottom: 1px solid #f0f2f5;
        }
        [data-color-scheme="dark"] .bmd-table th { border-bottom-color: rgba(255,255,255,0.07); color: rgba(255,255,255,0.3); }
        .bmd-table td {
            padding: 10px 12px;
            color: #333;
            border-bottom: 1px solid #f7f8fa;
            vertical-align: middle;
        }
        [data-color-scheme="dark"] .bmd-table td { color: #ccc; border-bottom-color: rgba(255,255,255,0.04); }
        .bmd-table tbody tr:hover td { background: #f9fafb; }
        [data-color-scheme="dark"] .bmd-table tbody tr:hover td { background: rgba(255,255,255,0.03); }
        .bmd-badge-active { background: rgba(37,211,102,0.12); color: #1ea952; padding: 3px 9px; border-radius: 9999px; font-size: 11px; font-weight: 700; }
        .bmd-badge-completed { background: rgba(33,128,141,0.12); color: #21808D; padding: 3px 9px; border-radius: 9999px; font-size: 11px; font-weight: 700; }
        .bmd-badge-paused { background: rgba(245,166,35,0.12); color: #d97706; padding: 3px 9px; border-radius: 9999px; font-size: 11px; font-weight: 700; }
        .bmd-loading-row { text-align: center; padding: 28px; color: #aaa; font-size: 13px; }
        .bmd-table-footer { margin-top: 12px; font-size: 12px; color: #aaa; text-align: right; }
        .bmd-page-info { cursor: pointer; }

        /* ── Today's Performance ── */
        .bmd-perf-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
