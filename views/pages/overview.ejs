<!-- Overview Section — Bulk Messaging Dashboard -->
<div id="dashboard-overview" class="dashboard-section">

    <!-- Page Header Bar -->
    <div class="bmd-topbar">
        <div class="bmd-topbar-left">
            <h1 class="bmd-title">Bulk Messaging Dashboard</h1>
        </div>
        <div class="bmd-topbar-right">
            <div class="bmd-search">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search campaigns, contacts…">
            </div>
            <div class="bmd-user-area">
                <div class="bmd-icon-btn" title="Messages"><i class="fas fa-envelope"></i></div>
                <div class="bmd-icon-btn" title="Notifications"><i class="fas fa-bell"></i></div>
                <div class="bmd-user-chip">
                    <div class="bmd-avatar"><i class="fas fa-user"></i></div>
                    <span class="bmd-user-name" id="bmd-username">User</span>
                    <i class="fas fa-chevron-down" style="font-size:10px;opacity:0.6;"></i>
                </div>
            </div>
            <button class="bmd-btn-new-campaign" onclick="document.querySelector('[data-section=messages]').click()">
                <i class="fas fa-plus"></i> New Campaign
            </button>
        </div>
    </div>

    <!-- Metric Cards -->
    <div class="bmd-body">
        <div class="bmd-metrics-row">
            <!-- Active Campaigns -->
            <div class="bmd-metric-card">
                <div class="bmd-metric-inner">
                    <div>
                        <div class="bmd-metric-label">Key Metrics</div>
                        <div class="bmd-metric-value" id="bmd-campaigns" data-stat="activeCampaigns">—</div>
                        <div class="bmd-metric-sub">active campaigns</div>
                    </div>
                    <div class="bmd-metric-icon bmd-icon-campaigns">
                        <i class="fas fa-bullhorn"></i>
                    </div>
                </div>
            </div>
            <!-- Messages -->
            <div class="bmd-metric-card">
                <div class="bmd-metric-inner">
                    <div>
                        <div class="bmd-metric-label">Messages</div>
                        <div class="bmd-metric-value" id="bmd-messages" data-stat="totalMessages">—</div>
                        <div class="bmd-metric-sub">messages sent</div>
                    </div>
                    <div class="bmd-metric-icon bmd-icon-messages">
                        <i class="fas fa-paper-plane"></i>
                    </div>
                </div>
            </div>
            <!-- Contacts -->
            <div class="bmd-metric-card">
                <div class="bmd-metric-inner">
                    <div>
                        <div class="bmd-metric-label">Contacts</div>
                        <div class="bmd-metric-value" id="bmd-contacts" data-stat="contactsReached">—</div>
                        <div class="bmd-metric-sub">contacts reached</div>
                    </div>
                    <div class="bmd-metric-icon bmd-icon-contacts">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
            <!-- Response Rate -->
            <div class="bmd-metric-card">
                <div class="bmd-metric-inner">
                    <div>
                        <div class="bmd-metric-label">Response</div>
                        <div class="bmd-metric-value" id="bmd-response" data-stat="responseRate">—</div>
                        <div class="bmd-metric-sub">response rate</div>
                    </div>
                    <div class="bmd-metric-icon bmd-icon-response">
                        <i class="fas fa-reply"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="bmd-charts-row">
            <!-- Total Sent Chart -->
            <div class="bmd-chart-card bmd-chart-wide">
                <div class="bmd-card-header">
                    <span class="bmd-card-title">Total Sent</span>
                    <div class="bmd-chart-legend">
                        <span class="bmd-legend-dot" style="background:#25D366;"></span>
                        <span class="bmd-legend-text">Messages</span>
                    </div>
                </div>
                <canvas id="totalSentChart" height="140"></canvas>
            </div>
            <!-- Engagement Rate Chart -->
            <div class="bmd-chart-card">
                <div class="bmd-card-header">
                    <span class="bmd-card-title">Engagement Rate</span>
                    <div class="bmd-chart-legend">
                        <span class="bmd-legend-dot" style="background:#25D366;"></span>
                        <span class="bmd-legend-text">Opens</span>
                        <span class="bmd-legend-dot" style="background:#21808D;margin-left:10px;"></span>
                        <span class="bmd-legend-text">Clicks</span>
                    </div>
                </div>
                <canvas id="engagementChart" height="140"></canvas>
            </div>
        </div>

        <!-- Bottom Row -->
        <div class="bmd-bottom-row">
            <!-- Campaign Overview Table -->
            <div class="bmd-table-card">
                <div class="bmd-card-header">
                    <span class="bmd-card-title">Campaign Overview</span>
                    <a href="#" class="bmd-view-all" onclick="document.querySelector('[data-section=messages]').click();return false;">View all</a>
                </div>
                <div class="bmd-table-wrap">
                    <table class="bmd-table">
                        <thead>
                            <tr>
                                <th>Campaign</th>
                                <th>Status</th>
                                <th>Sent</th>
                                <th>Delivered</th>
                                <th>Read</th>
                                <th>Clicks</th>
                            </tr>
                        </thead>
                        <tbody id="bmd-campaign-tbody">
                            <tr>
                                <td colspan="6" class="bmd-loading-row">
                                    <span class="spinner-border spinner-border-sm text-success me-2"></span> Loading campaigns…
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="bmd-table-footer">
                    <span class="bmd-page-info">Page 1 &rsaquo;</span>
                </div>
            </div>

            <!-- Right column -->
            <div class="bmd-right-col">
                <!-- Today's Performance -->
                <div class="bmd-perf-card">
                    <div class="bmd-card-header">
                        <span class="bmd-card-title">Today's Performance</span>
                    </div>
                    <canvas id="todayPerfChart" height="120"></canvas>
                </div>

                <!-- Quick Actions -->
                <div class="bmd-qa-card">
                    <div class="bmd-card-header">
                        <span class="bmd-card-title">Quick Actions</span>
                    </div>
                    <div class="bmd-qa-list">
                        <a class="bmd-qa-item" href="#" onclick="document.querySelector('[data-section=messages]').click();return false;">
                            <div class="bmd-qa-icon"><i class="fas fa-bullhorn"></i></div>
                            <span>Quick campaign</span>
                            <i class="fas fa-chevron-right bmd-qa-arrow"></i>
                        </a>
                        <a class="bmd-qa-item" href="#" onclick="document.querySelector('[data-section=analytics]').click();return false;">
                            <div class="bmd-qa-icon"><i class="fas fa-chart-bar"></i></div>
                            <span>Quick performance</span>
                            <i class="fas fa-chevron-right bmd-qa-arrow"></i>
                        </a>
                        <a class="bmd-qa-item" href="#" onclick="document.querySelector('[data-section=sessions]').click();return false;">
                            <div class="bmd-qa-icon"><i class="fas fa-address-book"></i></div>
                            <span>Manage contacts</span>
                            <i class="fas fa-chevron-right bmd-qa-arrow"></i>
                        </a>
                    </div>
                </div>

                <!-- API Key -->
                <div class="bmd-apikey-card">
                    <div class="bmd-card-header">
                        <span class="bmd-card-title"><i class="fas fa-key me-2" style="color:#25D366;"></i>API Key</span>
                        <span class="badge fs-6" id="plan-badge" style="background:linear-gradient(135deg,#25D366,#21808D);color:#fff;border-radius:9999px;padding:4px 10px;font-size:11px!important;">Loading…</span>
                    </div>
                    <div class="input-group mt-2">
                        <input type="password" class="form-control form-control-sm" id="api-key" value="Loading..." readonly style="font-size:12px;">
                        <div id="api-key-buttons"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Styles for Bulk Messaging Dashboard -->
    <style>
        /* ── Top Bar ── */
        .bmd-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 28px;
