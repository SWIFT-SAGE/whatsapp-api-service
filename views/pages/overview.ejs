            margin-bottom: 22px;
        }
        @media (max-width: 1100px) { .bmd-metrics-row { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 600px) { .bmd-metrics-row { grid-template-columns: 1fr; } }
        .bmd-metric-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
