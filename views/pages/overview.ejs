        /* ── API Key card ── */
        .bmd-apikey-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            border: 1px solid #f0f2f5;
        }
        [data-color-scheme="dark"] .bmd-apikey-card { background: #1a2a1f; border-color: rgba(255,255,255,0.07); }

        /* ── sparkline placeholder ── */
        .sparkline-wrap { display: none; }
