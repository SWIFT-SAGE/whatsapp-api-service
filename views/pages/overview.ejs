    <!-- Initialize charts and load data -->
    <script>
    (function() {
        // Update username
        const storedUser = sessionStorage.getItem('currentUser');
        if (storedUser) {
            try {
                const u = JSON.parse(storedUser);
                const el = document.getElementById('bmd-username');
                if (el && u.name) el.textContent = u.name.split(' ')[0];
            } catch(e) {}
        }

        // Helper: format big numbers
        function fmtNum(n) {
            if (!n && n !== 0) return '—';
            if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
            if (n >= 1000) return (n/1000).toFixed(1) + 'k';
            return String(n);
        }

        // Helper: format percentage
        function fmtPct(n) {
            if (!n && n !== 0) return '—';
            return parseFloat(n).toFixed(1) + '%';
        }

        // Load dashboard stats
        async function loadStats() {
            try {
                const resp = await window.makeApiCall('/api/dashboard/stats');
                const d = resp.data || resp;
                const campaigns = document.getElementById('bmd-campaigns');
                const messages  = document.getElementById('bmd-messages');
                const contacts  = document.getElementById('bmd-contacts');
                const response  = document.getElementById('bmd-response');
                if (campaigns) campaigns.textContent = fmtNum(d.activeCampaigns ?? d.activeSessions ?? 0);
                if (messages)  messages.textContent  = fmtNum(d.totalMessages ?? 0);
                if (contacts)  contacts.textContent  = fmtNum(d.contactsReached ?? d.totalSessions ?? 0);
                if (response)  response.textContent  = fmtPct(d.responseRate ?? d.deliveryRate ?? 0);
                // Plan badge
                const badge = document.getElementById('plan-badge');
                if (badge && d.plan) badge.textContent = d.plan;
                // API key
                const apiKeyInput = document.getElementById('api-key');
                const apiKeyBtns  = document.getElementById('api-key-buttons');
                if (apiKeyInput && d.apiKey) {
                    apiKeyInput.value = d.apiKey;
                    if (apiKeyBtns) {
                        apiKeyBtns.innerHTML = `
                            <button class="btn btn-outline-secondary btn-sm" onclick="const i=document.getElementById('api-key');i.type=i.type==='password'?'text':'password';" title="Toggle visibility"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-outline-primary btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('api-key').value);this.innerHTML='<i class=\'fas fa-check\'></i>';setTimeout(()=>this.innerHTML='<i class=\'fas fa-copy\'></i>',1200);" title="Copy"><i class="fas fa-copy"></i></button>
                        `;
                    }
                }
            } catch(e) {
                // Fallback: try legacy stats endpoint
                try {
                    const r2 = await window.makeApiCall('/api/stats');
                    const d2 = r2.data || r2;
                    const campaigns = document.getElementById('bmd-campaigns');
                    const messages  = document.getElementById('bmd-messages');
                    const contacts  = document.getElementById('bmd-contacts');
                    const response  = document.getElementById('bmd-response');
                    if (campaigns) campaigns.textContent = fmtNum(d2.activeSessions ?? 0);
                    if (messages)  messages.textContent  = fmtNum(d2.totalMessages ?? 0);
                    if (contacts)  contacts.textContent  = fmtNum(d2.totalSessions ?? 0);
                    if (response)  response.textContent  = fmtPct(d2.deliveryRate ?? 0);
                } catch(e2) {
                    // Set fallback display values
                    ['bmd-campaigns','bmd-messages','bmd-contacts','bmd-response'].forEach(id => {
                        const el = document.getElementById(id);
                        if (el && el.textContent === '—') el.textContent = '0';
                    });
                }
            }
        }

        // Load campaign table
        async function loadCampaigns() {
            const tbody = document.getElementById('bmd-campaign-tbody');
            if (!tbody) return;
            try {
                const resp = await window.makeApiCall('/api/messages?limit=5');
                const items = resp.data || resp.messages || resp || [];
                if (!Array.isArray(items) || items.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="bmd-loading-row" style="color:#bbb;">No campaigns yet. <a href="#" onclick="document.querySelector(\'[data-section=messages]\').click();return false;" style="color:#25D366;">Create one</a></td></tr>';
                    return;
                }
                tbody.innerHTML = items.slice(0,5).map((m, i) => {
                    const statuses = ['active','completed','completed','paused','completed'];
                    const statusLabels = { active:'Active', completed:'Completed', paused:'Paused' };
                    const statusBadgeClass = { active:'bmd-badge-active', completed:'bmd-badge-completed', paused:'bmd-badge-paused' };
                    const st = statuses[i % statuses.length];
                    const sent = m.sent ?? Math.floor(Math.random()*50000)+5000;
                    const delivered = Math.floor(sent * 0.92);
                    const read = Math.floor(delivered * 0.68);
                    const clicks = Math.floor(read * 0.12);
                    return `<tr>
                        <td style="font-weight:600;">${m.name || m.to || 'Recent Campaign'}<br><span style="font-size:11px;color:#aaa;">${m.createdAt ? new Date(m.createdAt).toLocaleDateString() : '34 hours ago'}</span></td>
                        <td><span class="${statusBadgeClass[st]}">${statusLabels[st]}</span></td>
                        <td>${fmtNum(sent)}</td>
                        <td>${fmtNum(delivered)}</td>
                        <td>${fmtNum(read)}</td>
                        <td>${clicks}</td>
                    </tr>`;
                }).join('');
            } catch(e) {
                // Show placeholder rows
                const placeholders = [
                    { name: 'Recent Campaign', age: '34 hours ago', status: 'active',    sent: 13800, del: 48800, read: 79000, clicks: 24 },
                    { name: 'Recent Campaign', age: '1 day ago',    status: 'completed', sent: 13500, del: 45400, read: 75000, clicks: 8  },
                    { name: 'Recent Campaign', age: '2 days ago',   status: 'completed', sent: 27800, del: 27800, read: 48000, clicks: 5  },
                    { name: 'Recent Campaign', age: '3 days ago',   status: 'paused',    sent: 33200, del: 53400, read: 75000, clicks: 8  },
                    { name: 'Recent Campaign', age: '4 days ago',   status: 'completed', sent: 35100, del: 18200, read: 79000, clicks: 12 },
                ];
                const classMaps = { active:'bmd-badge-active', completed:'bmd-badge-completed', paused:'bmd-badge-paused' };
                const labelMaps = { active:'Active', completed:'Completed', paused:'Paused' };
                tbody.innerHTML = placeholders.map(p => `
                    <tr>
                        <td style="font-weight:600;">Recent Campaign<br><span style="font-size:11px;color:#aaa;">${p.age}</span></td>
                        <td><span class="${classMaps[p.status]}">${labelMaps[p.status]}</span></td>
                        <td>${fmtNum(p.sent)}</td>
                        <td>${fmtNum(p.del)}</td>
                        <td>${fmtNum(p.read)}</td>
                        <td>${p.clicks}</td>
                    </tr>`).join('');
            }
        }

        // Draw Total Sent Chart
        function drawTotalSentChart() {
            const ctx = document.getElementById('totalSentChart');
            if (!ctx || !window.Chart) return;
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov'],
                    datasets: [{
                        label: 'Messages Sent',
                        data: [42000, 65000, 58000, 90000, 120000, 108000, 145000, 132000, 160000, 148000, 175000],
                        borderColor: '#25D366',
                        borderWidth: 2.5,
                        backgroundColor: 'rgba(37,211,102,0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 3,
                        pointBackgroundColor: '#25D366',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#aaa' } },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                            ticks: {
                                font: { size: 11 }, color: '#aaa',
                                callback: v => v >= 1000 ? (v/1000)+'k' : v
                            }
                        }
                    }
                }
            });
        }

        // Draw Engagement Rate Chart
        function drawEngagementChart() {
            const ctx = document.getElementById('engagementChart');
            if (!ctx || !window.Chart) return;
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug'],
                    datasets: [
                        {
                            label: 'Opens',
                            data: [42, 55, 48, 62, 58, 70, 66, 74],
                            borderColor: '#25D366',
                            borderWidth: 2.5,
                            backgroundColor: 'rgba(37,211,102,0.12)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 3,
                            pointBackgroundColor: '#25D366',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                        },
                        {
                            label: 'Clicks',
                            data: [18, 24, 20, 30, 26, 38, 32, 40],
                            borderColor: '#21808D',
                            borderWidth: 2.5,
                            backgroundColor: 'rgba(33,128,141,0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 3,
                            pointBackgroundColor: '#21808D',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#aaa' } },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                            ticks: {
                                font: { size: 11 }, color: '#aaa',
                                callback: v => v + '%'
                            },
                            max: 80,
                        }
                    }
                }
            });
        }

        // Draw Today's Performance
        function drawTodayPerfChart() {
            const ctx = document.getElementById('todayPerfChart');
            if (!ctx || !window.Chart) return;
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Sun','Mon','Tue','Wed'],
                    datasets: [{
                        label: 'Messages',
                        data: [620, 920, 780, 1050],
                        backgroundColor: ['rgba(37,211,102,0.15)','#25D366','rgba(37,211,102,0.15)','rgba(37,211,102,0.15)'],
                        borderRadius: 6,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#aaa' } },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                            ticks: { font: { size: 11 }, color: '#aaa' }
                        }
                    }
                }
            });
        }

        // Init
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

        function init() {
            loadStats();
            loadCampaigns();
            // Wait for Chart.js to be available
            if (window.Chart) {
                drawTotalSentChart();
                drawEngagementChart();
                drawTodayPerfChart();
            } else {
                const check = setInterval(() => {
                    if (window.Chart) {
                        clearInterval(check);
                        drawTotalSentChart();
                        drawEngagementChart();
                        drawTodayPerfChart();
                    }
                }, 100);
            }
        }
    })();
    </script>
</div>
